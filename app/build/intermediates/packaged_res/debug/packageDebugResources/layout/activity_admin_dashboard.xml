<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/admin_dashboard_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f8fafc"
    tools:context=".AdminDashboardActivity">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nsv_admin_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="100dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/admin_bottom_nav">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Top Blue/Purple Background -->
            <View
                android:id="@+id/v_admin_header_bg"
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:background="@drawable/bg_admin_header_purple" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

            <!-- Header Content -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/ll_admin_top_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="24dp"
                android:paddingTop="54dp"
                android:paddingBottom="24dp">

                <TextView
                    android:id="@+id/tv_today_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sunday, Mar 15"
                    android:textColor="#BCFFFFFF"
                    android:textSize="14sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tv_greeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Good Morning,"
                    android:textColor="#E0E7FF"
                    android:textSize="18sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_today_date" />

                <TextView
                    android:id="@+id/tv_admin_name_display"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="System Administrator"
                    android:textColor="@color/white"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_greeting" />

                <TextView
                    android:id="@+id/tv_role_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_tag_glass"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="Administrator"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_admin_name_display" />

                <FrameLayout
                    android:id="@+id/iv_admin_notifications_bell"
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:background="@drawable/bg_squircle_glass"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="@id/tv_role_badge">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_bell"
                        android:tint="@color/white" />
                    
                    <!-- Notification Badge -->
                    <TextView
                        android:id="@+id/tv_notif_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minWidth="18dp"
                        android:minHeight="18dp"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="10dp"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/bg_notif_badge"
                        android:gravity="center"
                        android:paddingHorizontal="4dp"
                        android:text="0"
                        android:textColor="@color/white"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:visibility="gone"
                        tools:visibility="visible"
                        tools:text="1" />
                </FrameLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- STATS OVERVIEW SECTION -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:letterSpacing="0.05"
                    android:text="SYSTEM OVERVIEW"
                    android:textColor="#94a3b8"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <!-- STATS GRID SECTION (2x2) -->
                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:rowCount="2"
                    android:alignmentMode="alignMargins"
                    android:columnOrderPreserved="false"
                    android:paddingTop="16dp">

                    <!-- Square 1: Active Patients -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_active_patients"
                        android:layout_width="0dp"
                        android:layout_height="140dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="8dp"
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#f1f5f9">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="16dp"
                            android:gravity="center">
                            <FrameLayout
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@drawable/bg_circle_soft_green"
                                android:layout_marginBottom="12dp">
                                <ImageView
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_pulse_green"
                                    android:tint="#10b981" />
                            </FrameLayout>
                            <TextView
                                android:id="@+id/tv_active_patients_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#1e293b"
                                android:textSize="22sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Active Patients"
                                android:textColor="#64748b"
                                android:textSize="12sp"
                                android:gravity="center" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Square 2: Active Clinicians -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_active_clinicians"
                        android:layout_width="0dp"
                        android:layout_height="140dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="8dp"
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#f1f5f9">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="16dp"
                            android:gravity="center">
                            <FrameLayout
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@drawable/bg_circle_soft_green"
                                android:layout_marginBottom="12dp">
                                <ImageView
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_stethoscope"
                                    android:tint="#10b981" />
                            </FrameLayout>
                            <TextView
                                android:id="@+id/tv_active_clinicians_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#1e293b"
                                android:textSize="22sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Active Clinicians"
                                android:textColor="#64748b"
                                android:textSize="12sp"
                                android:gravity="center" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>


                    <!-- Square 3: Total Patients -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_total_patients"
                        android:layout_width="0dp"
                        android:layout_height="140dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="8dp"
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#f1f5f9">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="16dp"
                            android:gravity="center">
                            <FrameLayout
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@drawable/bg_circle_light_blue"
                                android:layout_marginBottom="12dp">
                                <ImageView
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_patients_nav"
                                    android:tint="#3b82f6" />
                            </FrameLayout>
                            <TextView
                                android:id="@+id/tv_total_patients_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#1e293b"
                                android:textSize="22sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total Patients"
                                android:textColor="#64748b"
                                android:textSize="12sp"
                                android:gravity="center" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Square 4: Total Clinicians -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_total_clinicians"
                        android:layout_width="0dp"
                        android:layout_height="140dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="8dp"
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#f1f5f9">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="16dp"
                            android:gravity="center">
                            <FrameLayout
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@drawable/bg_circle_soft_purple"
                                android:layout_marginBottom="12dp">
                                <ImageView
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_stethoscope"
                                    android:tint="@color/admin_purple" />
                            </FrameLayout>
                            <TextView
                                android:id="@+id/tv_total_clinicians_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#1e293b"
                                android:textSize="22sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total Clinicians"
                                android:textColor="#64748b"
                                android:textSize="12sp"
                                android:gravity="center" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </GridLayout>
                
                <!-- NEW: User Distribution Pie Chart -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#f1f5f9">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="User Distribution"
                            android:textColor="#0f172a"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Breakdown by user roles"
                            android:textColor="#94a3b8"
                            android:textSize="14sp" />

                        <com.github.mikephil.charting.charts.PieChart
                            android:id="@+id/chart_distribution"
                            android:layout_width="match_parent"
                            android:layout_height="240dp"
                            android:layout_marginTop="12dp" />
                        
                        <!-- Custom Legend matching the image -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginTop="16dp"
                            android:paddingHorizontal="8dp"
                            android:layout_marginBottom="8dp">

                            <!-- Patients Row -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:paddingVertical="8dp">
                                <View
                                    android:layout_width="12dp"
                                    android:layout_height="12dp"
                                    android:background="@drawable/bg_circle_soft_purple"
                                    android:backgroundTint="#9333ea" />
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginStart="16dp"
                                    android:text="Patients"
                                    android:textColor="#334155"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />
                                <TextView
                                    android:id="@+id/tv_patients_percentage"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0%"
                                    android:textColor="#1e293b"
                                    android:textSize="18sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <!-- Clinicians Row -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:paddingVertical="8dp">
                                <View
                                    android:layout_width="12dp"
                                    android:layout_height="12dp"
                                    android:background="@drawable/bg_circle_soft_blue"
                                    android:backgroundTint="#3b82f6" />
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginStart="16dp"
                                    android:text="Clinicians"
                                    android:textColor="#334155"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />
                                <TextView
                                    android:id="@+id/tv_clinicians_percentage"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0%"
                                    android:textColor="#1e293b"
                                    android:textSize="18sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <!-- Admins Row -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:paddingVertical="8dp">
                                <View
                                    android:layout_width="12dp"
                                    android:layout_height="12dp"
                                    android:background="@drawable/bg_circle_soft_blue"
                                    android:backgroundTint="#bfdbfe" />
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginStart="16dp"
                                    android:text="Admins"
                                    android:textColor="#334155"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />
                                <TextView
                                    android:id="@+id/tv_admins_percentage"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0%"
                                    android:textColor="#1e293b"
                                    android:textSize="18sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- NEW: System Data Export Section -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="#fdfaff"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#e9d5ff">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                app:cardBackgroundColor="@color/white"
                                app:cardCornerRadius="12dp"
                                app:cardElevation="0dp"
                                app:strokeWidth="1dp"
                                app:strokeColor="#f1f5f9">
                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_document_text"
                                    android:tint="@color/admin_purple" />
                            </com.google.android.material.card.MaterialCardView>
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="16dp"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="System Data Export"
                                    android:textColor="#1e293b"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Generate platform analytics dump"
                                    android:textColor="#6b7280"
                                    android:textSize="12sp" />
                            </LinearLayout>
                        </LinearLayout>
                        
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Download a comprehensive CSV dump of patient records and system logs."
                            android:textColor="#6b7280"
                            android:textSize="13sp" />
                        
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_generate_csv"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:layout_marginTop="16dp"
                            android:text="Generate CSV Dump"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            app:cornerRadius="16dp"
                            app:backgroundTint="@color/admin_purple"
                            app:icon="@drawable/ic_sync_refresh"
                            app:iconTint="@color/white"
                            app:iconGravity="textStart" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Access Control Information Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="24dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#f1f5f9">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_shield_check"
                                android:tint="@color/admin_purple" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:text="Access Control"
                                android:textColor="@color/admin_purple"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:lineSpacingExtra="4dp"
                            android:text="Admin manages user accounts and system health only. Clinical decisions and patient treatment remain clinician-controlled."
                            android:textColor="#7c3aed"
                            android:textSize="13sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
            </LinearLayout>
        </FrameLayout>
    </androidx.core.widget.NestedScrollView>

                <!-- Bottom Navigation Bar -->
    <LinearLayout
        android:id="@+id/admin_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="84dp"
        android:paddingBottom="12dp"
        android:background="@color/white"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:elevation="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Dashboard -->
        <LinearLayout
            android:id="@+id/admin_nav_dashboard"
            style="@style/BottomNavTab">
            <ImageView style="@style/BottomNavIcon" android:src="@drawable/ic_dashboard_grid" android:tint="#7C3AED" />
            <TextView style="@style/BottomNavText" android:text="Dashboard" android:textColor="#7C3AED" android:textStyle="bold" />
        </LinearLayout>

        <!-- Clinicians -->
        <LinearLayout
            android:id="@+id/admin_nav_clinicians"
            style="@style/BottomNavTab">
             <ImageView style="@style/BottomNavIcon" android:src="@drawable/ic_stethoscope" />
            <TextView style="@style/BottomNavText" android:text="Clinicians" />
        </LinearLayout>

        <!-- Patients -->
        <LinearLayout
            android:id="@+id/admin_nav_patients"
            style="@style/BottomNavTab">
            <ImageView style="@style/BottomNavIcon" android:src="@drawable/ic_patients_nav" />
            <TextView style="@style/BottomNavText" android:text="Patients" />
        </LinearLayout>

        <!-- Settings -->
        <LinearLayout
            android:id="@+id/admin_nav_settings"
            style="@style/BottomNavTab">
            <ImageView style="@style/BottomNavIcon" android:src="@drawable/ic_user_silhouette" />
            <TextView style="@style/BottomNavText" android:text="Profile" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>



