<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cl_admin_notif_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    tools:context=".AdminNotificationsActivity">

    <!-- Clean White Header (Matches Manage Clinicians) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:paddingHorizontal="24dp"
        android:paddingTop="52dp"
        android:paddingBottom="20dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_chevron_left"
            android:tint="#1E293B"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tv_mark_all_read"
            app:layout_constraintStart_toEndOf="@id/iv_back"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tv_header_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="System Activity"
                android:textColor="#0F172A"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_mark_all_read"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mark All Read"
            android:textColor="@color/admin_purple"
            android:fontFamily="sans-serif-medium"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_reactivation_requests"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        android:paddingVertical="12dp"
        app:layout_constraintBottom_toTopOf="@id/admin_bottom_nav"
        app:layout_constraintTop_toBottomOf="@id/header_layout"
        tools:listitem="@layout/item_reactivation_request" />

    <LinearLayout
        android:id="@+id/ll_empty_state"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/rv_reactivation_requests"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header_layout">

        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/ic_bell"
            android:alpha="0.2"
            app:tint="@color/admin_purple" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="No Pending Requests"
            android:textColor="#94A3B8"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Your inbox is currently clear."
            android:textColor="#94A3B8"
            android:textSize="14sp" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/pb_admin_notif"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:visibility="gone"
        android:indeterminateTint="@color/admin_purple"
        app:layout_constraintBottom_toBottomOf="@id/rv_reactivation_requests"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/rv_reactivation_requests" />

    <!-- Bottom Navigation Bar -->
    <LinearLayout
        android:id="@+id/admin_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="84dp"
        android:paddingBottom="12dp"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:elevation="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Dashboard -->
        <LinearLayout
            android:id="@+id/admin_nav_dashboard"
            style="@style/BottomNavTab">
            <ImageView style="@style/BottomNavIcon" android:src="@drawable/ic_dashboard_grid" />
            <TextView style="@style/BottomNavText" android:text="Dashboard" />
        </LinearLayout>

        <!-- Clinicians -->
        <LinearLayout
            android:id="@+id/admin_nav_clinicians"
            style="@style/BottomNavTab">
             <ImageView style="@style/BottomNavIcon" android:src="@drawable/ic_stethoscope" />
            <TextView style="@style/BottomNavText" android:text="Clinicians" />
        </LinearLayout>

        <!-- Patients -->
        <LinearLayout
            android:id="@+id/admin_nav_patients"
            style="@style/BottomNavTab">
            <ImageView style="@style/BottomNavIcon" android:src="@drawable/ic_patients_nav" />
            <TextView style="@style/BottomNavText" android:text="Patients" />
        </LinearLayout>

        <!-- Settings -->
        <LinearLayout
            android:id="@+id/admin_nav_settings"
            style="@style/BottomNavTab">
            <ImageView style="@style/BottomNavIcon" android:src="@drawable/ic_settings" />
            <TextView style="@style/BottomNavText" android:text="Settings" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
