<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".ReportIssueActivity">

    <!-- Header Toolbar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/tb_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="48dp"
        android:paddingBottom="16dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/ic_chevron_right"
            android:rotation="180"
            android:tint="@color/text_title"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Report Issue"
            android:textColor="@color/text_title"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="16dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/iv_back" />

    </androidx.constraintlayout.widget.ConstraintLayout>


    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/tb_header"
        app:layout_constraintBottom_toTopOf="@id/btn_continue">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select all that apply:"
                android:textColor="#9CA3AF"
                android:textSize="14sp"
                android:layout_marginBottom="16dp" />

            <!-- Checkbox Items -->
            
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="#F0F2F5"
                app:strokeWidth="1dp">
                <CheckBox
                    android:id="@+id/cb_loose_bracket"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Loose Bracket / Band"
                    android:textColor="#374151"
                    android:textSize="16sp"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:paddingStart="12dp"
                    android:layoutDirection="ltr"
                    android:background="?attr/selectableItemBackground"
                    android:button="@drawable/cb_custom_selector"
                    android:layout_marginHorizontal="16dp" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="#F0F2F5"
                app:strokeWidth="1dp">
                <CheckBox
                    android:id="@+id/cb_poking_wire"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Poking Wire"
                    android:textColor="#374151"
                    android:textSize="16sp"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:paddingStart="12dp"
                    android:layoutDirection="ltr"
                    android:background="?attr/selectableItemBackground"
                    android:button="@drawable/cb_custom_selector"
                    android:layout_marginHorizontal="16dp" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="#F0F2F5"
                app:strokeWidth="1dp">
                <CheckBox
                    android:id="@+id/cb_lost_aligner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Lost Aligner"
                    android:textColor="#374151"
                    android:textSize="16sp"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:paddingStart="12dp"
                    android:layoutDirection="ltr"
                    android:background="?attr/selectableItemBackground"
                    android:button="@drawable/cb_custom_selector"
                    android:layout_marginHorizontal="16dp" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="#F0F2F5"
                app:strokeWidth="1dp">
                <CheckBox
                    android:id="@+id/cb_severe_pain"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Severe Pain"
                    android:textColor="#374151"
                    android:textSize="16sp"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:paddingStart="12dp"
                    android:layoutDirection="ltr"
                    android:background="?attr/selectableItemBackground"
                    android:button="@drawable/cb_custom_selector"
                    android:layout_marginHorizontal="16dp" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="#F0F2F5"
                app:strokeWidth="1dp">
                <CheckBox
                    android:id="@+id/cb_swollen_gums"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Swollen Gums"
                    android:textColor="#374151"
                    android:textSize="16sp"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:paddingStart="12dp"
                    android:layoutDirection="ltr"
                    android:background="?attr/selectableItemBackground"
                    android:button="@drawable/cb_custom_selector"
                    android:layout_marginHorizontal="16dp" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="#F0F2F5"
                app:strokeWidth="1dp">
                <CheckBox
                    android:id="@+id/cb_broken_appliance"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Broken Appliance"
                    android:textColor="#374151"
                    android:textSize="16sp"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:paddingStart="12dp"
                    android:layoutDirection="ltr"
                    android:background="?attr/selectableItemBackground"
                    android:button="@drawable/cb_custom_selector"
                    android:layout_marginHorizontal="16dp" />
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Button -->
    <Button
        android:id="@+id/btn_continue"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="32dp"
        android:backgroundTint="#85CDA7"
        android:text="Continue"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="16sp"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

