<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/unified_login_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB"
    tools:context=".UnifiedLoginActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="24dp"
            android:paddingTop="80dp"
            android:paddingBottom="40dp">

            <!-- Logo -->
            <ImageView
                android:id="@+id/iv_logo"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/ic_tooth_logo_main"
                android:contentDescription="OrthoGuide Logo" />

            <!-- App Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="ORTHOGUIDE"
                android:textColor="#10B981"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.15" />

            <!-- Subtitle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Sign in to your OrthoGuide account"
                android:textColor="#6B7280"
                android:textSize="14sp" />

            <!-- Login Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E5E7EB">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <!-- Role Tabs -->
                    <LinearLayout
                        android:id="@+id/ll_role_tabs"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:orientation="horizontal"
                        android:background="@drawable/bg_tab_container"
                        android:padding="4dp"
                        android:layout_marginBottom="20dp">

                        <TextView
                            android:id="@+id/tab_patient"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="Patient"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:background="@drawable/bg_tab_active" />

                        <TextView
                            android:id="@+id/tab_doctor"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="Doctor"
                            android:textSize="14sp"
                            android:textColor="#6B7280" />

                        <TextView
                            android:id="@+id/tab_admin"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="Admin"
                            android:textSize="14sp"
                            android:textColor="#6B7280" />

                    </LinearLayout>

                    <!-- Error Message -->
                    <TextView
                        android:id="@+id/tv_error_message"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_error_banner"
                        android:padding="12dp"
                        android:textColor="#DC2626"
                        android:textSize="13sp"
                        android:visibility="gone"
                        android:layout_marginBottom="12dp" />

                    <!-- User ID Label -->
                    <TextView
                        android:id="@+id/tv_id_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Patient ID"
                        android:textColor="#374151"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <!-- User ID Input -->
                    <EditText
                        android:id="@+id/et_user_id"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_edittext_rounded"
                        android:hint="e.g. PAT192210667"
                        android:inputType="text"
                        android:paddingHorizontal="16dp"
                        android:textColor="#1F2937"
                        android:textColorHint="#9CA3AF"
                        android:textSize="15sp" />

                    <!-- Password Label -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Password"
                        android:textColor="#374151"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <!-- Password Input -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_edittext_rounded">

                        <EditText
                            android:id="@+id/et_password"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@null"
                            android:hint="Enter your password"
                            android:inputType="textPassword"
                            android:paddingStart="16dp"
                            android:paddingEnd="48dp"
                            android:textColor="#1F2937"
                            android:textColorHint="#9CA3AF"
                            android:textSize="15sp" />

                        <ImageView
                            android:id="@+id/iv_toggle_password"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="end|center_vertical"
                            android:layout_marginEnd="16dp"
                            android:src="@drawable/ic_visibility_off"
                            android:tint="#9CA3AF"
                            android:clickable="true"
                            android:focusable="true"
                            android:contentDescription="Toggle password visibility" />
                    </FrameLayout>

                    <!-- Sign In Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_sign_in"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="24dp"
                        android:text="Sign In"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:backgroundTint="#10B981"
                        app:cornerRadius="8dp" />

                    <!-- Loading Spinner (hidden by default) -->
                    <ProgressBar
                        android:id="@+id/pb_loading"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:visibility="gone"
                        android:indeterminateTint="#10B981" />

                    <!-- Forgot Password -->
                    <TextView
                        android:id="@+id/tv_forgot_password"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="16dp"
                        android:text="Forgot Password?"
                        android:textColor="#10B981"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:padding="4dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Security Note -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:alpha="0.5">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_shield_check"
                    android:tint="#6B7280"
                    android:contentDescription="Secure" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="Secured with end-to-end encryption"
                    android:textColor="#6B7280"
                    android:textSize="12sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>

