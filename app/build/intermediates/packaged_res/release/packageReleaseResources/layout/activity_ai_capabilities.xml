<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/ai_capabilities_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".AiCapabilitiesActivity">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/ll_header_ai"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/iv_back_ai"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_chevron_right"
            android:rotation="180"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:tint="#1A1C21" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="@string/ai_capabilities_title"
            android:textColor="#1A1C21"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:id="@+id/header_divider_ai"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0F2F5"
        app:layout_constraintTop_toBottomOf="@id/ll_header_ai" />

    <!-- Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/header_divider_ai"
        app:layout_constraintBottom_toTopOf="@id/btn_understand">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Card 1: What AI Can Do -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#F0F2F5">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Vertical Indicator -->
                    <View
                        android:layout_width="4dp"
                        android:layout_height="match_parent"
                        android:background="#10B981" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="16dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_check_green" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:text="@string/what_ai_can_do"
                                android:textColor="#1A1C21"
                                android:textSize="18sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- List Items -->
                        <LinearLayout style="@style/BulletListContainer">
                            <ImageView style="@style/BulletDotGreen" />
                            <TextView style="@style/BulletText" android:text="@string/ai_can_do_1" />
                        </LinearLayout>

                        <LinearLayout style="@style/BulletListContainer">
                            <ImageView style="@style/BulletDotGreen" />
                            <TextView style="@style/BulletText" android:text="@string/ai_can_do_2" />
                        </LinearLayout>

                        <LinearLayout style="@style/BulletListContainer">
                            <ImageView style="@style/BulletDotGreen" />
                            <TextView style="@style/BulletText" android:text="@string/ai_can_do_3" />
                        </LinearLayout>

                        <LinearLayout style="@style/BulletListContainer">
                            <ImageView style="@style/BulletDotGreen" />
                            <TextView style="@style/BulletText" android:text="@string/ai_can_do_4" />
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card 2: What AI Cannot Do -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#F0F2F5">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Vertical Indicator -->
                    <View
                        android:layout_width="4dp"
                        android:layout_height="match_parent"
                        android:background="#EF4444" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="16dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_cross_red" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:text="@string/what_ai_cannot_do"
                                android:textColor="#1A1C21"
                                android:textSize="18sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- List Items -->
                        <LinearLayout style="@style/BulletListContainer">
                            <ImageView style="@style/BulletDotRed" />
                            <TextView style="@style/BulletText" android:text="@string/ai_cannot_do_1" />
                        </LinearLayout>

                        <LinearLayout style="@style/BulletListContainer">
                            <ImageView style="@style/BulletDotRed" />
                            <TextView style="@style/BulletText" android:text="@string/ai_cannot_do_2" />
                        </LinearLayout>

                        <LinearLayout style="@style/BulletListContainer">
                            <ImageView style="@style/BulletDotRed" />
                            <TextView style="@style/BulletText" android:text="@string/ai_cannot_do_3" />
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Warning Box -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_warning_note"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="top">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_warning_orange" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="@string/emergency_warning_text"
                    android:textColor="#92400E"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_understand"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_margin="24dp"
        android:text="@string/i_understand"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:backgroundTint="@color/brand_green"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

