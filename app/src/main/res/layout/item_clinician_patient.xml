<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mcv_patient_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="#F1F5F9">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <FrameLayout
            android:id="@+id/fl_avatar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_circle_light_blue"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <TextView
                android:id="@+id/tv_patient_initials"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="JD"
                android:textColor="#2563EB"
                android:textSize="16sp"
                android:textStyle="bold" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_patient_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:text="Patient Name"
            android:textColor="#111827"
            android:textSize="18sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:maxLines="1"
            app:layout_constraintStart_toEndOf="@id/fl_avatar"
            app:layout_constraintTop_toTopOf="@id/fl_avatar"
            app:layout_constraintEnd_toStartOf="@id/tv_patient_status" />

        <TextView
            android:id="@+id/tv_patient_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_tag_green_soft"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:text="ON TRACK"
            android:textColor="#065F46"
            android:textSize="11sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/tv_patient_name"
            app:layout_constraintEnd_toStartOf="@id/iv_arrow"
            app:layout_constraintTop_toTopOf="@id/tv_patient_name" />

        <ImageView
            android:id="@+id/iv_arrow"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_chevron_right"
            android:tint="#CBD5E1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tv_patient_name"
            app:layout_constraintBottom_toBottomOf="@id/tv_patient_name" />

        <TextView
            android:id="@+id/tv_patient_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="ID: 100982000"
            android:textColor="#9CA3AF"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="@id/tv_patient_name"
            app:layout_constraintTop_toBottomOf="@id/tv_patient_name" />

        <TextView
            android:id="@+id/tv_patient_stage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_tag_grey"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="Treatment Stage"
            android:textColor="#475569"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="@id/tv_patient_name"
            app:layout_constraintTop_toBottomOf="@id/tv_patient_id" />

        <LinearLayout
            android:id="@+id/ll_appointment_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_tag_yellow"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            app:layout_constraintStart_toStartOf="@id/tv_patient_name"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_patient_stage">
            <ImageView
                android:id="@+id/iv_appointment_icon"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_clock_outline"
                android:tint="#D97706" />
            <TextView
                android:id="@+id/tv_appointment_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="No session scheduled"
                android:textColor="#D97706"
                android:textSize="12sp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
