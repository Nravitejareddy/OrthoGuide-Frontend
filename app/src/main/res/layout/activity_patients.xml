                                android:textColor="#D97706"
                                android:textSize="12sp" />
                        </LinearLayout>

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Patient 3: Sarah Anderson -->
                <com.google.android.material.card.MaterialCardView
