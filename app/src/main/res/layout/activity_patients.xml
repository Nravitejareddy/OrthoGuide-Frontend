                            android:textSize="18sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toEndOf="@id/fl_avatar_2"
                            app:layout_constraintTop_toTopOf="@id/fl_avatar_2" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="216dp"
                            android:background="@drawable/bg_tag_red"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="4dp"
                            android:text="CRITICAL"
                            android:textColor="#991B1B"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="@id/tv_name_2"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="@id/tv_name_2" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_chevron_right"
                            android:tint="#CBD5E1"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@id/tv_name_2"
                            app:layout_constraintBottom_toBottomOf="@id/tv_name_2" />

                        <TextView
                            android:id="@+id/tv_id_2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="ID: 100982100"
                            android:textColor="#9CA3AF"
                            android:textSize="14sp"
                            app:layout_constraintStart_toStartOf="@id/tv_name_2"
                            app:layout_constraintTop_toBottomOf="@id/tv_name_2" />

                        <TextView
                            android:id="@+id/tv_stage_tag_2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/bg_tag_grey"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:text="Bonding / First Trays"
                            android:textColor="#475569"
                            android:textSize="12sp"
                            app:layout_constraintStart_toStartOf="@id/tv_name_2"
                            app:layout_constraintTop_toBottomOf="@id/tv_id_2" />

                        <LinearLayout
                            android:id="@+id/ll_appt_status_2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/bg_tag_yellow"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="6dp"
