                        <TextView
                            android:id="@+id/tv_stage_tag_3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/bg_tag_grey"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:text="Alignment Phase"
                            android:textColor="#475569"
                            android:textSize="12sp"
                            app:layout_constraintStart_toStartOf="@id/tv_name_3"
                            app:layout_constraintTop_toBottomOf="@id/tv_id_3" />

                        <LinearLayout
                            android:id="@+id/ll_appt_status_3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
