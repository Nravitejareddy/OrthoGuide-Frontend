                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_user_silhouette"
                                android:tint="#2563EB" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tv_name_1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="Robert Chen"
                            android:textColor="#111827"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toEndOf="@id/fl_avatar_1"
                            app:layout_constraintTop_toTopOf="@id/fl_avatar_1" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="216dp"
                            android:background="@drawable/bg_tag_attention_yellow"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="4dp"
                            android:text="ATTENTION"
                            android:textColor="#B45309"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="@id/tv_name_1"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="@id/tv_name_1" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_chevron_right"
                            android:tint="#CBD5E1"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@id/tv_name_1"
                            app:layout_constraintBottom_toBottomOf="@id/tv_name_1" />

                        <TextView
                            android:id="@+id/tv_id_1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="ID: 100982300"
                            android:textColor="#9CA3AF"
                            android:textSize="14sp"
                            app:layout_constraintStart_toStartOf="@id/tv_name_1"
                            app:layout_constraintTop_toBottomOf="@id/tv_name_1" />

                        <TextView
                            android:id="@+id/tv_stage_tag_1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/bg_tag_grey"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:text="Debonding &amp; Retention"
                            android:textColor="#475569"
                            android:textSize="12sp"
                            app:layout_constraintStart_toStartOf="@id/tv_name_1"
                            app:layout_constraintTop_toBottomOf="@id/tv_id_1" />

                        <LinearLayout
                            android:id="@+id/ll_appt_status_1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/bg_tag_yellow"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="6dp"
                            app:layout_constraintStart_toStartOf="@id/tv_name_1"
                            app:layout_constraintTop_toBottomOf="@+id/tv_stage_tag_1">
                            <ImageView
                                android:id="@+id/iv_appt_icon_1"
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:src="@drawable/ic_clock_outline"
                                android:tint="#D97706" />
                            <TextView
                                android:id="@+id/tv_appt_status_1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:text="No appointment scheduled"
                                android:textColor="#D97706"
                                android:textSize="12sp" />
                        </LinearLayout>

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Patient 2: James Wilson -->
                <com.google.android.material.card.MaterialCardView
