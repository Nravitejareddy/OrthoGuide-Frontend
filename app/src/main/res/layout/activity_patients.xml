                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Patient 4: Emily Davis -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_patient_4"
