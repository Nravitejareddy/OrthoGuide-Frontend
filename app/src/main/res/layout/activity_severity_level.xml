<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".SeverityLevelActivity">

    <!-- Header Toolbar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/tb_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="48dp"
        android:paddingBottom="16dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/ic_chevron_right"
            android:rotation="180"
            android:tint="@color/text_title"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Severity Level"
            android:textColor="@color/text_title"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="16dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/iv_back" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Main Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        app:layout_constraintTop_toBottomOf="@id/tb_header"
        app:layout_constraintBottom_toTopOf="@id/btn_submit">

        <!-- A spacer to push content slightly up from center -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.8" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="How much pain are you in?"
            android:textColor="@color/text_title"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="On a scale of 1 to 10"
            android:textColor="#9CA3AF"
            android:textSize="18sp" />

        <GridLayout
            android:id="@+id/gl_numbers"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:columnCount="5"
            android:rowCount="2"
            android:useDefaultMargins="false">

            <!-- Row 1 -->
            <TextView style="@style/GridItem" android:text="1" />
            <TextView style="@style/GridItem" android:text="2" />
            <TextView style="@style/GridItem" android:text="3" />
            <TextView style="@style/GridItem" android:text="4" />
            <TextView style="@style/GridItem" android:text="5" />

            <!-- Row 2 -->
            <TextView style="@style/GridItem" android:text="6" />
            <TextView style="@style/GridItem" android:text="7" />
            <TextView style="@style/GridItem" android:text="8" />
            <TextView style="@style/GridItem" android:text="9" />
            <TextView style="@style/GridItem" android:text="10" />

        </GridLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginHorizontal="32dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="start"
                android:text="MILD"
                android:textColor="#9CA3AF"
                android:textSize="12sp"
                android:letterSpacing="0.05"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="MODERATE"
                android:textColor="#9CA3AF"
                android:textSize="12sp"
                android:letterSpacing="0.05"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:text="SEVERE"
                android:textColor="#9CA3AF"
                android:textSize="12sp"
                android:letterSpacing="0.05"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- A spacer to push content slightly up from center -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>

    <!-- Bottom Button -->
    <Button
        android:id="@+id/btn_submit"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="32dp"
        android:backgroundTint="#85CDA7"
        android:text="Submit Report"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="16sp"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
