                    <gradient
                        android:centerX="50"
                        android:centerY="50"
                        android:gradientRadius="50"
                        android:type="radial">
                        <item android:color="@color/brand_green" android:offset="0.0"/>
                        <item android:color="@color/brand_green_dark" android:offset="1.0"/>

                    </gradient>
                </aapt:attr>
            </path>
            <!-- Three Dots -->
            <path
                android:fillColor="@color/white"
                android:pathData="M35,50 m-4,0 a4,4 0,1 1,8 0 a4,4 0,1 1,-8 0" />
            <path
                android:fillColor="@color/white"
                android:pathData="M50,50 m-4,0 a4,4 0,1 1,8 0 a4,4 0,1 1,-8 0" />
            <path
