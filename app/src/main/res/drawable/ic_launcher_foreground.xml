            android:pathData="M37,45 m-5,0 a5,9 0,1 1,10 0 a5,9 0,1 1,-10 0" />
        <path
            android:fillColor="@color/brand_green"
            android:pathData="M63,45 m-5,0 a5,9 0,1 1,10 0 a5,9 0,1 1,-10 0" />

        <!-- Smile -->
        <path
            android:fillColor="#00000000"
            android:strokeColor="@color/brand_green"
            android:strokeWidth="6"
            android:strokeLineCap="round"
            android:pathData="M38,62 C42,70 58,70 62,62" />
            
        <!-- Chat Bubble - Positioned exactly as in activity_splash.xml (offset from bottom-end) -->
        <group
            android:translateX="68"
            android:translateY="24"
            android:scaleX="0.38"
            android:scaleY="0.38">
            <path
                android:pathData="M20,20 H80 C90,20 95,25 95,35 V65 C95,75 90,80 80,80 H45 L15,95 L30,80 H20 C10,80 5,75 5,65 V35 C5,25 10,20 20,20 Z">
