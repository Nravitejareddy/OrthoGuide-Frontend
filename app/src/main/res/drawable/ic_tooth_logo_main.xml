<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background Square -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/brand_green" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <!-- Master Logo with correct internal padding -->
    <item
        android:bottom="16dp"
        android:left="16dp"
        android:right="16dp"
        android:top="16dp"
        android:drawable="@drawable/ic_brand_logo_master">
    </item>
</layer-list>
